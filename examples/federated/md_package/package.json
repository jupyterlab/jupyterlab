{
  "name": "@jupyterlab/example-federated-md",
  "version": "3.6.0-alpha.4",
  "private": true,
  "main": "./index.js",
  "scripts": {
    "build": "npm run clean && jupyter-builder build --development=true --core-package-file ../core_package/package.json .",
    "clean": "rimraf ../labextensions/@jupyterlab/example-federated-md"
  },
  "dependencies": {
    "@jupyterlab/application": "^4.6.0-alpha.4",
    "@jupyterlab/example-federated-middle": "^3.5.0-alpha.4",
    "@jupyterlab/markdownviewer-extension": "^4.6.0-alpha.4",
    "@lumino/widgets": "^2.7.5"
  },
  "devDependencies": {
    "@jupyter/builder": "^0.0.8",
    "rimraf": "~5.0.5"
  },
  "jupyterlab": {
    "extension": true,
    "schemaDir": "./schema",
    "outputDir": "../labextensions/@jupyterlab/example-federated-md",
    "mimeExtension": "./mime.js"
  }
}
